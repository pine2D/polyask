{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "version": "0.4.0",
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": { "default_popup": "popup/popup.html" },
  "permissions": ["storage", "tabs", "system.display"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://www.doubao.com/*",
        "https://chat.deepseek.com/*",
        "https://www.qianwen.com/*",
        "https://www.kimi.com/*",
        "https://yuanbao.tencent.com/*",
        "https://chatglm.cn/*"
      ],
      "js": ["i18n.js", "content/core.js", "content/adapters-intl.js", "content/adapters-cn.js", "content/pill.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "switch-think": {
      "suggested_key": { "default": "Alt+T" },
      "description": "__MSG_cmdThink__"
    },
    "switch-fast": {
      "suggested_key": { "default": "Alt+Y" },
      "description": "__MSG_cmdFast__"
    },
    "open-console": {
      "suggested_key": { "default": "Alt+Q" },
      "description": "__MSG_cmdOpenConsole__"
    }
  }
}
