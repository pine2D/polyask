{
  "manifest_version": 3,
  "name": "AI Model Switcher",
  "description": "一键在深度思考与快速模型间切换（Claude/ChatGPT/Gemini/DeepSeek/豆包/千问/Kimi）",
  "version": "0.1.0",
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://www.doubao.com/*",
        "https://chat.deepseek.com/*",
        "https://www.qianwen.com/*",
        "https://www.kimi.com/*"
      ],
      "js": ["content/core.js", "content/adapters.js", "content/pill.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "switch-think": {
      "suggested_key": { "default": "Alt+T" },
      "description": "切换到深度思考（最高思考档）"
    },
    "switch-fast": {
      "suggested_key": { "default": "Alt+Y" },
      "description": "切换到快速模型"
    }
  }
}
